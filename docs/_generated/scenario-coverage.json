{
  "knownScenarios": [
    {
      "tag": "apigateway-cors-preflight",
      "description": "API Gateway CORS preflight (OPTIONS) handling — CDK auto-generates `Method` with both Integration.IntegrationResponses and MethodResponses arrays."
    },
    {
      "tag": "cdk-defensive-vpc-deps-relax",
      "description": "CDK-defensive route DependsOn relaxation for VPC Lambda parallelization."
    },
    {
      "tag": "cfn-macro-expansion",
      "description": "CloudFormation macro / `Fn::Transform` expansion via transient CFn changeset round-trip (SAM, AWS::Include, AWS::LanguageExtensions, custom macros). See `docs/design/463-cfn-macros.md`."
    },
    {
      "tag": "cloudfront-oai-attribute-enrichment",
      "description": "CloudFront OAI `S3CanonicalUserId` attribute enrichment (the attribute is not on `GetCloudFrontOriginAccessIdentity` directly)."
    },
    {
      "tag": "cross-cutting-deploy-destroy",
      "description": "Broad real-AWS regression set (39+ resource VPC+NAT+CF+Lambda+SQS or comparable breadth). Refreshes the integ-broad gate."
    },
    {
      "tag": "custom-resource-async-poll",
      "description": "Custom Resource backed by Lambda + cfn-response via S3 pre-signed URL polling."
    },
    {
      "tag": "deletion-policy-retain",
      "description": "DeletionPolicy: Retain skip on destroy (schema v5 recorded value wins over template)."
    },
    {
      "tag": "drift-revert-roundtrip",
      "description": "cdkd drift detection + `--revert` round-trip via each provider.update()."
    },
    {
      "tag": "export-to-cfn-handover",
      "description": "cdkd → CloudFormation migration via 2-phase IMPORT changeset + phase-2 UPDATE."
    },
    {
      "tag": "globaltable-cross-region-replica",
      "description": "DynamoDB GlobalTable cross-region replica add/remove serialization (AWS rejects multiple ReplicaUpdates per UpdateTable call)."
    },
    {
      "tag": "iam-policy-propagation-retry",
      "description": "CREATE retry with exponential backoff after IAM-EC2/Lambda eventual-consistency race."
    },
    {
      "tag": "lambda-vpc-subnet-sg-deletion-order",
      "description": "Subnet/SecurityGroup must delete AFTER Lambda::Function to avoid ENI DependencyViolation."
    },
    {
      "tag": "legacy-bucket-name-fallback",
      "description": "New region-free `cdkd-state-{account}` vs legacy `cdkd-state-{account}-{region}` bucket fallback resolution."
    },
    {
      "tag": "local-apigateway-server",
      "description": "`cdkd local start-api` HTTP server with route discovery + per-Lambda warm container pool."
    },
    {
      "tag": "local-ecs-service",
      "description": "`cdkd local start-service` long-running ECS Service emulator: replica pool, restart-on-exit, SIGINT teardown."
    },
    {
      "tag": "local-ecs-service-connect",
      "description": "`cdkd local start-service` Service Connect + Cloud Map peer discovery: ServiceConnectConfiguration + ServiceRegistries parsing, in-process Cloud Map registry, docker `--add-host` DNS overlay (Issue #460)."
    },
    {
      "tag": "local-ecs-task",
      "description": "`cdkd local run-task` ECS TaskDefinition with docker network + AWS-published metadata sidecar."
    },
    {
      "tag": "local-from-state-substitution",
      "description": "`cdkd local invoke|run-task --from-state` substitutes intrinsic-valued env/secret/role references against deployed cdkd state + AWS pseudo parameters."
    },
    {
      "tag": "local-lambda-rie-container",
      "description": "`cdkd local invoke` container-Lambda (Code.ImageUri) against RIE — local-build OR ECR-pull asset resolution."
    },
    {
      "tag": "local-lambda-rie-zip",
      "description": "`cdkd local invoke` ZIP-runtime Lambda against the AWS Lambda Runtime Interface Emulator (RIE) container."
    },
    {
      "tag": "local-websocket-api",
      "description": "`cdkd local start-api` WebSocket API support: ws upgrade + $connect/$disconnect/$default/custom route dispatch + @connections data plane."
    },
    {
      "tag": "migrate-from-bare-cfn",
      "description": "`cdkd migrate --from-cfn-stack <name>` end-to-end: bare CFn → `cdk migrate` codegen → 2-pass resource mapping → cdkd state + optional retire."
    },
    {
      "tag": "migrate-from-cfn-handover",
      "description": "CloudFormation → cdkd migration via `--migrate-from-cloudformation` (UpdateStack with Retain + DeleteStack)."
    },
    {
      "tag": "multi-region-state-key",
      "description": "Same stackName + different regions = independent state files (`version: 2` region-prefixed key layout)."
    },
    {
      "tag": "multi-stack-getstackoutput",
      "description": "Cross-stack `Fn::GetStackOutput` weak reference resolution (cdkd-specific, no CFn Export)."
    },
    {
      "tag": "multi-stack-importvalue-strong-ref",
      "description": "Cross-stack `Fn::ImportValue` strong-reference + persistent exports index (schema v4 imports[])."
    },
    {
      "tag": "nat-gateway-cleanup",
      "description": "NAT Gateway destroy + dependent route cleanup (unconditional `waitUntilNatGatewayDeleted` on destroy)."
    },
    {
      "tag": "rds-aurora-cluster-instance",
      "description": "RDS Aurora cluster + writer instance create/destroy with the 30-min wait budget + DBProxy/DBProxyTargetGroup family."
    },
    {
      "tag": "remove-protection-bypass",
      "description": "`--remove-protection` flag bypassing AWS-side deletion-protection on supported types."
    },
    {
      "tag": "state-bucket-region-resolve",
      "description": "State-bucket S3 client auto-detects bucket region via `GetBucketLocation` regardless of caller-profile region."
    },
    {
      "tag": "state-schema-migration",
      "description": "Legacy v1 / v2 state schema auto-migrates on next write; old binary fails clearly on a newer schema."
    },
    {
      "tag": "vpc-lambda-cr-race",
      "description": "Custom Resource invocation against a VPC Lambda mid-deploy (ENI-attach race window)."
    },
    {
      "tag": "vpc-lambda-eni-release",
      "description": "Lambda hyperplane ENI cleanup after DeleteFunction (5-30 min eventually consistent)."
    }
  ],
