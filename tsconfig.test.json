{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "exactOptionalPropertyTypes": false,
    "noPropertyAccessFromIndexSignature": false,
    "noUncheckedIndexedAccess": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/**/*",
    "tests/setup.ts",
    "tests/unit/**/*.ts",
    "types/**/*",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
