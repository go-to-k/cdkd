# Override the parent integ .gitignore so the BuildKit Lambda's source
# files are tracked. The Dockerfile builds against
# ${LAMBDA_TASK_ROOT}/app.js and the AWS Lambda Node.js base image's
# RIE entrypoint expects the .js extension.
!docker/*.js
!docker/Dockerfile
# Allow the dummy secret used to verify RUN --mount=type=secret. The
# content is a fixed integ literal (not real credentials) — the integ
# asserts its sha256 surfaces through the build path.
!docker/secret.txt
